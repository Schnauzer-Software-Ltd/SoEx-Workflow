<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PiiMaker.Manager.Membership.Interface</RootNamespace>
    <AssemblyName>PiiMaker.Manager.Membership.Interface</AssemblyName>
  </PropertyGroup>

  <!-- The Membership method's CONTRACTS, in its own assembly named for the namespace it holds
       (<Company>.Manager.<Component>.Interface): the inbound-trigger seam (IMembershipManager) plus the
       governed-step contracts the flows bind (Native/Portable IMembershipManager). The trigger seam is
       exposed over HTTP by the hand-written controller in PiiMaker.Hosting. The implementation and the rest
       of the method live in PiiMaker, which references this. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\..\..\src\SoEx.Workflow.Abstractions\SoEx.Workflow.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="SoEx.Abstractions" />
  </ItemGroup>

</Project>
