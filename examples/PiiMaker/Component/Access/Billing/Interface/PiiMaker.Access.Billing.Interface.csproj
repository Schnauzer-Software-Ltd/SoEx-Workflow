<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>PiiMaker.Access.Billing.Interface</RootNamespace>
    <AssemblyName>PiiMaker.Access.Billing.Interface</AssemblyName>
  </PropertyGroup>

  <!-- The Billing access-component CONTRACT, in its own assembly named for the namespace it holds
       (<Company>.<Tier>.<Component>.Interface) — the same component-per-assembly convention as
