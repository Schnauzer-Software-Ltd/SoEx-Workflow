    <ProjectReference Include="..\Interface\PiiMaker.Manager.Membership.Interface.csproj" />
    <!-- The manager only PROXIES to the workflow utility, so it references the Abstractions package only —
         never the implementation. -->
    <ProjectReference Include="..\..\..\..\..\..\src\SoEx.Method.Workflow.Abstractions\SoEx.Method.Workflow.Abstractions.csproj" />
    <ProjectReference Include="..\..\..\Access\Billing\Interface\PiiMaker.Access.Billing.Interface.csproj" />
    <ProjectReference Include="..\..\..\Access\Identity\Interface\PiiMaker.Access.Identity.Interface.csproj" />
    <ProjectReference Include="..\..\..\Access\Provisioning\Interface\PiiMaker.Access.Provisioning.Interface.csproj" />
    <ProjectReference Include="..\..\..\Access\Retention\Interface\PiiMaker.Access.Retention.Interface.csproj" />
    <ProjectReference Include="..\..\..\Engine\Subscription\Interface\PiiMaker.Engine.Subscription.Interface.csproj" />
    <ProjectReference Include="..\..\..\..\iFx\PiiMaker.iFx.csproj" />
    <ProjectReference Include="..\..\..\..\..\..\src\SoEx.Workflow.Abstractions\SoEx.Workflow.Abstractions.csproj" />
  </ItemGroup>

</Project>
