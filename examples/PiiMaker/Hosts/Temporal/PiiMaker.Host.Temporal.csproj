<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>PiiMaker.Host.Temporal</RootNamespace>
    <AssemblyName>PiiMaker.Host.Temporal</AssemblyName>
  </PropertyGroup>

  <!-- Host on a real Temporal server. The shared composition stands up the membership system; the Temporal
       adapter reference brings the Temporalio SDK + the portable flow + native interceptor/activities. -->
  <ItemGroup>
    <ProjectReference Include="..\Common\PiiMaker.Hosting.csproj" />
    <ProjectReference Include="..\..\PiiMaker.csproj" />
    <ProjectReference Include="..\..\..\..\src\SoEx.Workflow.Temporal\SoEx.Workflow.Temporal.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- The static control-panel UI lives once in Shared/wwwroot; copy it into this host's output wwwroot. -->
  <Target Name="CopyControlPanelUi" AfterTargets="Build;Publish">
    <ItemGroup>
      <ControlPanelUi Include="..\Common\wwwroot\**\*" />
    </ItemGroup>
    <Copy SourceFiles="@(ControlPanelUi)"
          DestinationFiles="@(ControlPanelUi->'$(OutDir)wwwroot\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
