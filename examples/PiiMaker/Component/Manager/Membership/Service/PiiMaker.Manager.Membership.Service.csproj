  <PropertyGroup>
    <RootNamespace>PiiMaker.Manager.Membership.Service</RootNamespace>
    <AssemblyName>PiiMaker.Manager.Membership.Service</AssemblyName>
  </PropertyGroup>

  <!-- The Membership manager IMPLEMENTATION, in its own assembly. The manager orchestrates the Engine and
       Access components, so it references their CONTRACT assemblies (never their implementations) plus its
       own contract; it reaches the Workflow utility through its contract; it touches the governed core for
       the erasure events. -->
